# =================================================================
# Proj-2 — Environment variables za MQTT vs Kafka evaluaciju
# Kopirati u .env i prilagoditi vrednosti po scenariju.
# =================================================================

# --- Izbor brokera (mqtt ili kafka); postavlja se i u compose overlay ---
# BROKER=mqtt

# --- MQTT ---
MQTT_URL=mosquitto
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=iot/telemetry
MQTT_QOS=1                       # 0, 1 ili 2
MQTT_CLEAN_SESSION=true          # false za Scenario B (perzistentna sesija)

# --- Kafka ---
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=iot-telemetry
KAFKA_ACKS=all                   # 0, 1 ili all
KAFKA_LINGER_MS=5

# --- Ingestion / scheduler ---
NUM_DEVICES=100
RATE=100
DURATION_S=60
MODE=rate                        # rate ili realtime
TIME_SCALE=10.0                  # za realtime mode
DATA_CSV_PATH=/data/Data.csv

# --- Scenario D (E2E latency) ---
INJECT_HIGH_TEMP=false
INJECT_AT_S=10

# --- Storage ---
BATCH_SIZE=500
FLUSH_INTERVAL_MS=200
DB_ENABLED=true
DATABASE_URL=postgres://iot:iot@postgres:5432/iot

# --- Analytics (Tumbling Window) ---
WINDOW_SIZE_MS=10000
ALERT_THRESHOLD=50.0

# --- Portovi za /metrics ---
INGEST_METRICS_PORT=9091
STORAGE_METRICS_PORT=9093       # 9092 je Kafka broker port; izbegavati koliziju
ANALYTICS_METRICS_PORT=9090
